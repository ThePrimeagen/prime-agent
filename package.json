    "install:e2e:with-deps": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.13.5",
    "@typescript/native-preview": "^7.0.0-dev.20260322.1",
    "typescript": "^5.7.3"
  }
}
